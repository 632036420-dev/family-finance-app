{
  "buildCommand": "npm run build",
  "outputDirectory": ".vercel/output",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  },
  "env": {
    "DASHSCOPE_API_KEY": "@dashscope_api_key"
  }
}
