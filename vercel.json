{
  "version": 2,
  "builds": [
    { "src": "static/**/*", "use": "@vercel/static" },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/static/index.html" },
    { "src": "/(.*)", "dest": "/static/$1" }
  ],
  "env": {
    "DASHSCOPE_API_KEY": "@dashscope_api_key"
  }
}
